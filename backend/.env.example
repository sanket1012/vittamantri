TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
FRONTEND_URL=https://your-app.fly.dev

# Secret for signing JWT tokens. Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# Key used by the Telegram bot to authenticate with the backend. Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
BOT_API_KEY=your_bot_api_key_here

# Set to true only during local development
DEBUG=false
